*db_setFilterCreature
	maxnpcid = MAX_CREATURE_ID
	dim cbitorg, 30, maxnpcid
	// TODO 
	// Due to some magical shenanigans of the decompiler this section is regenerated every-time Ano adds a new monster.
	// This causes weird bugs in almost every version of CGX, so if you don't want to change every reference to "filter_creature".
	// Just change filter_creature(bullshit_number) to filter_creature(new_creature_id + 2) like the ones below.
	// Make sure the filter matches or you will get bugs like fairys spawning in lake dungeons or something.
	filter_creature(CREATURE_ID_MOMALARIA_THE_BLOODSUCKER + 2) = ""
	HMMBITON cbitorg(CHARA_BIT_FLOAT / 32, CREATURE_ID_MOMALARIA_THE_BLOODSUCKER), CHARA_BIT_FLOAT \ 32
	filter_creature(CREATURE_ID_BIG_MOSQUITO + 2) = "/nefia2/"
	HMMBITON cbitorg(CHARA_BIT_FLOAT / 32, CREATURE_ID_BIG_MOSQUITO), CHARA_BIT_FLOAT \ 32
	HMMBITON cbitorg(CHARA_BIT_RES_CONFUSE / 32, CREATURE_ID_BIG_MOSQUITO), CHARA_BIT_RES_CONFUSE \ 32
	HMMBITON cbitorg(CHARA_BIT_RES_BLIND / 32, CREATURE_ID_BIG_MOSQUITO), CHARA_BIT_RES_BLIND \ 32
	filter_creature(CREATURE_ID_QUEEN_SEDONA_THE_SAIL_GIRL + 2) = ""
	filter_creature(CREATURE_ID_PROPA_GANDAR_THE_MOBILE_ADVERTISER + 2) = ""
	filter_creature(CREATURE_ID_DEVIANT_MINECART + 2) = ""
	filter_creature(CREATURE_ID_MASKED_MUSANGOD + 2) = "/wild/nefia6/"
	filter_creature(CREATURE_ID_KAKOI_ANAGUMA + 2) = "/nefia1/"

	filter_creature(CREATURE_ID_MADEER + 2) = ""
	HMMBITON cbitorg(CHARA_BIT_SUPERIOR_RIDING / 32, CREATURE_ID_MADEER), CHARA_BIT_SUPERIOR_RIDING \ 32
