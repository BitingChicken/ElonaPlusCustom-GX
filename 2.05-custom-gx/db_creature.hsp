*db_creature_usernpc
	repeat usernpcmax
		/********** JAMES CUSTOM - CNPC SUMMONING - BEGINNING **********/
		if ( TweakData(TWEAK_GAMEPLAY_DISABLE_RANDOM_CNPC_SPAWN, TWEAK_CATEGORY_GAMEPLAY) != 0 ) {
			if ( gdata(GDATA_AREA) != AREA_MELKAWN & gdata(GDATA_AREA) != AREA_DERPHY ) {
				break
			}
		}
		/********** JAMES CUSTOM - CNPC SUMMONING - ENDING **********/
		if ( cmshade ) {
			break
		}
		if ( fltselect != userdata(12, cnt) ) {
			continue
		}
		if ( flttypemajor != FILTER_NOTHING ) {
			continue
		}
		if ( fltnrace != "" ) {
			if ( fltnrace != userdatan(2, cnt) ) {
				continue
			}
		}
		if ( userdata(2, cnt) > objlv ) {
			continue
		}
		if ( filtermax != 0 ) {
			dbtmp = 1
			dbtmp2 = cnt
			repeat filtermax
				if ( instr(userdatan(4, dbtmp2), 0, filtern(cnt)) == (-1) ) {
					dbtmp = 0
					break
				}
			loop
			if ( dbtmp == 0 ) {
				continue
			}
		}
		dbsum += limit(userdata(6, cnt), 1, 500) * 1000 / (500 + abs(objlv - userdata(2, cnt)) * 400) + 1
		unlist(dbmax) = cnt
		dblist(0, dbmax) = CREATURE_ID_USER, dbsum
		dbmax++
	loop
	if ( dbsum != 0 ) {
		exrand_rnd dbtmp, dbsum
		repeat dbmax
			if ( dblist(1, cnt) > dbtmp ) {
				dbid = dblist(0, cnt)
				if ( dbid == CREATURE_ID_USER ) {
					cdata(CDATA_USERNPC_ID, rc) = unlist(cnt)
				}
				break
			}
		loop
	}
	else {
		dbid = CREATURE_ID_BUG
	}
	return

